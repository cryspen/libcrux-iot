  · -- Step lemma application: dispatch ntt_at_layer_3_step_lemma_fc.
    intro acc k _h_ge h_le hinv
    have h_step := ntt_at_layer_3_step_lemma_fc zeta_i re h_bnd h_zeta acc k h_le hinv
