          show offset - sv < sv; omega
        have h_off_eq : offset = sv + j' := by
          show offset = sv + (offset - sv); omega
        have h_c_lt_16 : c < 16 := hc
        have h_c_minus_sv_lt_16 : c - sv < 16 := by omega
