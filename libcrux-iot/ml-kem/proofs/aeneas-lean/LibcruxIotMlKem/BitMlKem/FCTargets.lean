  rw [Spec.multiply_ntts_pure_eq_chunked_no_acc]
  -- Step 2: project lane ℓ through flatten_chunks via the inner list.
  unfold Spec.flatten_chunks
  -- The Std.Array.make's `.val[k]!` lookup is direct list-lookup.
