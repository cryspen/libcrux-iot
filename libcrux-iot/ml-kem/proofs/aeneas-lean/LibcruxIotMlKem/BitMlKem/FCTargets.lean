    -- After unfolding lift_poly the LHS reduces to ((List.range 256).map ...)[ℓ]!
    -- which rewrites to lift_fe (...) via getElem!_pos + getElem_map + getElem_range.
    unfold lift_poly
    show (((List.range 256).map
            (fun j => lift_fe
