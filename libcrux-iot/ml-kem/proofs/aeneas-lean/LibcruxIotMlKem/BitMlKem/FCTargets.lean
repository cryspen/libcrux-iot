    have := L2_8c.wrapping_mul_i32_no_overflow aj32 bj_zeta32 h_bnd
    rw [this, h_aj32_val, h_bj_zeta32_val]
  -- ===== Step: ai_bi_aj_bj = wrapping_add ai_bi aj_bj_zeta =====
