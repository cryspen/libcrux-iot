        by_contra h_ge
        push_neg at h_ge
        have h_ge2 : 2 * sv * i_end.val ≤ 2 * sv * group := Nat.mul_le_mul_left _ h_ge
        have : c ≥ 2 * sv * i_end.val := by
          have : 2 * sv * group ≤ c := by omega
          omega
        have h_rw : 2 * sv * i_end.val = 16 := by
          have h : 2 * i_end.val * sv = 2 * sv * i_end.val := by ring
          omega
        omega
