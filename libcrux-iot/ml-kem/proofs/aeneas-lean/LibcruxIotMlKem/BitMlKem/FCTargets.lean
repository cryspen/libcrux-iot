          Spec.chunk_inv_ntt_layer_2_step_pure (Spec.chunk_at (lift_poly re) k)
            (Spec.zeta_at (zeta_i.val - 2 * k - 1))
            (Spec.zeta_at (zeta_i.val - 2 * k - 2))))[k]'_ = _
