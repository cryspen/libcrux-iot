        simpa [Std.Do.SPred.down_pure] using hh
      simpa [L6_2_FC.step_post] using hP
    · have hP : L6_2_FC.step_post self b k (.done y) := by
        simpa [Std.Do.SPred.down_pure] using hh
      simpa [L6_2_FC.step_post] using hP

