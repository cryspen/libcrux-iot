        = ((out.val : ZMod 3329) * (2^16 : Int)
            + (ai.val : ZMod 3329) * (bj.val : ZMod 3329) * (2^16 : Int)
            + (aj.val : ZMod 3329) * (bi.val : ZMod 3329) * (2^16 : Int)) * 169 * 169 * 169 := by
    have := h_zmod
