            + ai.val * bj.val * (2 ^ 16 : Int)
            + aj.val * bi.val * (2 ^ 16 : Int)) : ZMod 3329)) :
    Spec.mont_reduce_pure (lift_fe_int r.val)
      = libcrux_iot_ml_kem.BitMlKem.SpecPure.FieldElement.add_pure
