    · rw [h_usize_bits, h64]; omega
  have h_size_eq : Aeneas.Std.UScalar.size Aeneas.Std.UScalarTy.Usize = 2 ^ System.Platform.numBits := by
    simp [Std.Usize.size, Usize.numBits]
