      unfold lift_vec
      show (t_as_ntt_final.val.map lift_poly)[r]! = _
      rw [getElem!_pos _ r (by rw [List.length_map, t_as_ntt_final.property]; exact hr)]
      rw [List.getElem_map]
      congr 1
      rw [getElem!_pos _ r (by rw [t_as_ntt_final.property]; exact hr)]
    rw [h_lift_t_at]
    congr 1
