        have h_done := h_done_a group h_group_lt offset h_off_lt_sv'
        rw [h_csv_eq_a, h_c_eq_a]
        exact h_done.symm
      · -- b-side: c ≥ sv. Set j' := offset - sv.
        simp only [if_neg h_off_lt_sv]
