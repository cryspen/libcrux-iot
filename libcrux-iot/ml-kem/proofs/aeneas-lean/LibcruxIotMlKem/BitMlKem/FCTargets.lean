    have h_body :
        libcrux_iot_ml_kem.matrix.compute_As_plus_e_loop1.body
          (vectortraitsOperationsInst := portable_ops_inst) matrix_A s_as_ntt error_as_ntt s_cache
          { start := k, «end» := K } t_as_ntt accumulator
