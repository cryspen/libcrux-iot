  have h_aj_bi_val : aj_bi_p.val = aj_v.val * bi_v.val := by
    have h_bnd : (aj32.val * bi32.val).natAbs < 2^31 := by
      rw [h_aj32_val, h_bi32_val, Int.natAbs_mul]
      have h_mul : aj_v.val.natAbs * bi_v.val.natAbs ≤ 3328 * 3328 :=
