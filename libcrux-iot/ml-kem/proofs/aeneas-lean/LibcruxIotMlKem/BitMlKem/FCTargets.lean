    -- Apply per-lane equality via h_lane_eq.
    -- Goal: ⟨List.map (fun k => add_pure ...), _⟩ = lift_poly t_as_ntt_final.val[r]!
    -- Both sides are Std.Array hacspec_ml_kem.parameters.FieldElement 256#usize.
