      = libcrux_iot_ml_kem.BitMlKem.SpecPure.FieldElement.add_pure
          (a.val[k]!) (b.val[k]!) := by
  unfold Spec.chunk_add_pure
  show ((List.range 16).map (fun i =>
        libcrux_iot_ml_kem.BitMlKem.SpecPure.FieldElement.add_pure
          (a.val[i]!) (b.val[i]!)))[k]! = _
