        libcrux_iot_ml_kem.BitMlKem.SpecPure.FieldElement.add_pure
          (a.val[i]!) (b.val[i]!))).length = 16 := by simp
  rw [getElem!_pos _ k (by rw [h_l]; exact hk)]
  rw [List.getElem_map, List.getElem_range]

