          ((vec.elements.val.map lift_fe)[i.val]!)
          (libcrux_iot_ml_kem.BitMlKem.SpecPure.FieldElement.mul_pure
            ((vec.elements.val.map lift_fe)[j.val]!) (lift_fe_mont zeta)))
